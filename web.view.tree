						<= Profile_title $mol_view
							sub /
								<= profile_title
						<= Profile_table $mol_view
							sub /
								<= L_name $mol_view
									sub /
										<= label_name
								<= V_name $mol_view
									sub /
										<= value_name
								<= L_surname $mol_view
									sub /
										<= label_surname
								<= V_surname $mol_view
									sub /
										<= value_surname
								<= L_login $mol_view
									sub /
										<= label_login
								<= V_login $mol_view
									sub /
										<= value_login
								<= L_role $mol_view
									sub /
										<= label_role
								<= V_role $mol_view
									sub /
										<= value_role
								<= L_school $mol_view
									sub /
										<= label_school
								<= V_school $mol_view
									sub /
										<= value_school
								<= L_id $mol_view
									sub /
										<= label_id
								<= V_id $mol_view
									sub /
										<= value_id
						<= Inv_section $mol_view
							sub /
								<= Inv_title $mol_view
									sub /
										<= invitations_title
								<= Inv_list $mol_list
									rows <= invitation_rows
						<= Ai_section $mol_view
							sub /
								<= Ai_heading $mol_view
									sub /
										<= ai_title
								<= Ai_btn $mol_button_minor
									click? <=> ai_click? null
									sub /
										<= ai_button_label
								<= Ai_block $mol_view
									attr *
