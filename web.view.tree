									sub /
										<= Ai_content $mol_view
											sub /
												<= ai_text
				<= Stats_side $mol_view
					sub /
						<= Stats_title $mol_view
							sub /
								<= stats_title
						<= Stats_column $mol_view
							sub /
								<= Done_card
								<= Work_card
								<= Overdue_card
								<= Rejected_card

