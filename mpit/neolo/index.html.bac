<!-- Modal: Teacher Assign Task -->
<div id="assignModal" class="modal-backdrop" hidden>
<div class="modal" style="width:min(100%,600px)" role="dialog">
<div class="modal-head"><div class="modal-title">Задать задание</div><button class="modal-close" id="closeAssignModal" type="button">×</button></div>
<div class="modal-form" style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px">
	<div class="modal-field">
		<label>Кому</label>
		<select id="assignTarget">
			<option value="class">Всему классу</option>
			<option value="student">Одному ученику</option>
		</select>
	</div>
	<div id="assignStudentRow" class="modal-field" style="display:none">
		<label>Выберите ученика</label>
		<select id="assignStudentSelect"></select>
	</div>
	<div class="modal-field full"><label>Название задания</label><div class="voice-input-wrap"><input id="assignTitle" placeholder="Например, Контрольная работа"/><button type="button" class="voice-btn" data-target="assignTitle" title="Голосовой ввод">🎤</button></div></div>
	<div class="modal-field"><label>Дата</label><input id="assignDate" type="date"/></div>
	<div class="modal-field time-field-wrap">
		<label>Время (начало–конец)</label>
		<div class="time-input-row">
			<input class="time-seg" id="assignStartH" type="number" min="0" max="23" placeholder="ЧЧ"/>
			<span class="time-sep">:</span>
			<input class="time-seg" id="assignStartM" type="number" min="0" max="59" placeholder="ММ"/>
			<span class="time-range-sep">–</span>
			<input class="time-seg" id="assignEndH" type="number" min="0" max="23" placeholder="ЧЧ"/>
			<span class="time-sep">:</span>
			<input class="time-seg" id="assignEndM" type="number" min="0" max="59" placeholder="ММ"/>
		</div>
		<div class="time-ai-row">
			<button class="time-ai-btn" type="button" id="predictAssignBtn">🤖 AI — предсказать время</button>
			<span id="predictAssignHint" style="font-size:12px;color:var(--g5);font-weight:700;"></span>
		</div>
	</div>
	<div class="modal-field full"><label>Описание</label><div class="voice-input-wrap"><textarea id="assignDesc" style="min-height:80px" placeholder="Что нужно сделать"></textarea><button type="button" class="voice-btn" data-target="assignDesc" title="Голосовой ввод">🎤</button></div></div>
	<!-- Файл учителя -->
	<div class="modal-field full">
		<label>Прикрепить файл (необязательно)</label>
		<div id="assignFileDropZone" class="file-upload-zone">
			<input type="file" id="assignFileInput" accept="*/*"/>
			<div class="file-upload-label">📎 <strong>Выберите файл</strong> или перетащите сюда</div>
		</div>
		<div id="assignFileAttachedInfo" style="display:none" class="file-attached">
			<span>📄</span><span id="assignFileAttachedName"></span>
			<button class="file-attached-remove" id="assignFileRemoveBtn" type="button">×</button>
		</div>
	</div>
	<div id="assignError" class="auth-error full" hidden></div>
	<div class="modal-actions full">
		<button class="modal-secondary" id="cancelAssignModal" type="button">Отмена</button>
		<button class="modal-primary" id="doAssign" type="button">Отправить задание</button>
	</div>
</div>
</div>
</div>


