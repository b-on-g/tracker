<!doctype html>
<html lang="ru">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>SchoolPlan</title>
<style>
:root {
	--g0:#ffffff; --g1:#f2f7f2; --g2:#ddeedd; --g3:#a8cca8;
	--g4:#2ecc5a; --g5:#1aa843; --g6:#0f7a30;
	--b0:#111111; --b1:#222222; --b2:#444444; --b3:#666666; --b4:#999999;
	--shadow: 0 16px 34px rgba(0,40,10,.10); --rx: 22px;
}
*{box-sizing:border-box;}
html,body{margin:0;min-height:100%;font-family:"Segoe UI",Arial,sans-serif;background:var(--g1);color:var(--b0);}
button,input,textarea,select{font:inherit;}
button{border:0;cursor:pointer;}
[hidden]{display:none!important;}

/* AUTH */
.auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:linear-gradient(135deg,#0f7a30 0%,#1aa843 55%,#2ecc5a 100%);}
.auth-card{width:min(100%,460px);background:#fff;border-radius:28px;box-shadow:0 32px 80px rgba(0,0,0,.22);padding:36px 32px 32px;max-height:93vh;overflow-y:auto;}
.auth-brand{font-size:28px;font-weight:800;color:var(--g5);margin-bottom:4px;}
.auth-brand span{color:var(--b0);}
.auth-sub{font-size:14px;color:var(--b3);margin-bottom:26px;}
.auth-tabs{display:flex;background:var(--g2);border-radius:12px;padding:4px;margin-bottom:22px;gap:4px;}
.auth-tab{flex:1;padding:10px;border-radius:9px;background:transparent;font-weight:700;font-size:14px;color:var(--b3);transition:background .18s,color .18s;}
.auth-tab.active{background:#fff;color:var(--g5);box-shadow:0 2px 8px rgba(0,100,30,.12);}
.auth-field{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;}
.auth-field label{font-size:13px;font-weight:700;color:var(--b2);}
.auth-field input{width:100%;padding:11px 14px;border:1.5px solid var(--g2);border-radius:11px;background:#fff;font-size:15px;outline:none;transition:border-color .18s;}
.auth-field input:focus{border-color:var(--g4);}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.two-col .auth-field{margin-bottom:0;}
.role-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.role-btn{padding:14px 8px;border-radius:14px;border:2px solid var(--g2);background:var(--g1);display:flex;flex-direction:column;align-items:center;gap:8px;font-weight:700;font-size:13px;color:var(--b2);transition:border-color .18s,background .18s,color .18s;}
.role-btn .role-icon{font-size:26px;}
.role-btn.selected{border-color:var(--g4);background:#e4f7eb;color:var(--g6);}
.auth-submit{width:100%;padding:13px;border-radius:13px;background:var(--g5);color:#fff;font-weight:800;font-size:16px;margin-top:6px;transition:background .18s;}
.auth-submit:hover{background:var(--g6);}
.auth-error{background:#fff0f0;color:#c0392b;border-radius:10px;padding:10px 14px;font-size:14px;font-weight:600;margin-bottom:14px;}

/* APP SHELL */
.app{width:100%;min-height:100vh;padding:12px;}
.shell{width:100%;min-height:calc(100vh - 24px);background:#fff;border-radius:28px;box-shadow:var(--shadow);padding:14px;}
.topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:12px;padding:0 6px;}
.brand{font-size:24px;font-weight:800;color:var(--b0);}
.brand em{color:var(--g5);font-style:normal;}
.topbar-btn{background:var(--b0);color:#fff;padding:11px 18px;border-radius:12px;font-weight:700;display:inline-flex;align-items:center;gap:10px;transition:background .18s;}
.topbar-btn:hover{background:var(--b1);}
.layout{display:grid;grid-template-columns:minmax(0,1fr) 132px;gap:12px;min-height:calc(100vh - 110px);}
.screen{min-height:100%;border-radius:var(--rx);padding:22px 24px;overflow:hidden;}
.screen.tasks{background:var(--g4);color:var(--b0);}
.screen.calendar{background:var(--b0);color:#fff;}
.screen.stats{background:var(--g6);color:#fff;}
.screen h1{margin:0 0 16px;font-size:clamp(30px,4vw,44px);line-height:1.02;font-weight:800;}
.section-title{margin:20px 0 12px;font-size:20px;font-weight:700;}
.screen.tasks .section-title{color:rgba(0,0,0,.6);}
.screen.calendar .section-title,.screen.stats .section-title{color:rgba(255,255,255,.7);}

/* SIDEBAR */
.sidebar{background:var(--g2);border-radius:var(--rx);padding:18px 12px;display:flex;flex-direction:column;justify-content:space-between;align-items:center;}
.side-stack{display:flex;flex-direction:column;gap:16px;width:100%;}
.side-item{background:transparent;border-radius:16px;padding:8px 4px;display:flex;flex-direction:column;align-items:center;gap:8px;transition:background .15s;position:relative;}
.side-item.active{background:rgba(255,255,255,.6);}
.side-item:hover:not(.active){background:rgba(255,255,255,.35);}
.side-circle{width:64px;height:64px;border-radius:999px;display:flex;align-items:center;justify-content:center;font-size:28px;}
.side-circle.g{background:var(--g4);}
.side-circle.bk{background:var(--b0);color:#fff;}
.side-circle.dg{background:var(--g6);color:#fff;}
.side-label{font-size:13px;font-weight:700;text-align:center;color:var(--b1);}
.side-badge{position:absolute;top:4px;right:8px;min-width:20px;height:20px;border-radius:999px;background:#e74c3c;color:#fff;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;padding:0 4px;}
.side-footer{width:100%;padding:0 4px;display:flex;flex-direction:column;gap:6px;}
.side-footer-btn{width:100%;background:transparent;padding:8px 6px;border-radius:10px;font-size:11px;font-weight:700;color:var(--b2);text-align:center;line-height:1.4;transition:background .15s;}
.side-footer-btn:hover{background:rgba(255,255,255,.55);}

/* CARDS */
.card-white{background:#fff;border-radius:14px;box-shadow:0 6px 16px rgba(0,0,0,.09);}

/* TASKS */
.tasks-group{display:flex;flex-direction:column;gap:12px;}
.task-card{width:100%;display:grid;grid-template-columns:auto minmax(0,1fr) auto;gap:14px;align-items:start;padding:14px 16px;text-align:left;}
.task-bullet{width:18px;height:18px;border-radius:999px;border:2.5px solid var(--g5);background:#fff;margin-top:3px;}
.task-name{font-size:17px;font-weight:700;margin-bottom:4px;word-break:break-word;color:var(--b0);}
.task-desc{font-size:13px;color:var(--b3);word-break:break-word;}
.task-meta{margin-top:4px;font-size:12px;font-weight:700;color:var(--g5);}
.task-deadline{font-size:13px;font-weight:700;color:var(--b2);white-space:nowrap;}
.task-meta-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-top:4px;}
.src-badge{font-size:11px;font-weight:700;padding:2px 7px;border-radius:999px;white-space:nowrap;}
.src-teacher{background:#e8f4ff;color:#0a58ca;}
.src-parent{background:#fff3e8;color:#b85c00;}
.src-self{background:var(--g2);color:var(--g6);}
.add-box{margin-top:22px;}
.add-trigger{width:100%;padding:14px 16px;display:flex;align-items:center;gap:14px;}
.add-icon{width:28px;height:28px;border-radius:999px;border:2px solid var(--g5);display:inline-flex;align-items:center;justify-content:center;color:var(--g5);font-size:18px;font-weight:800;}
.add-text{font-size:14px;font-weight:700;color:var(--g6);}

/* CALENDAR */
.calendar-layout{display:flex;flex-direction:column;gap:22px;}
.calendar-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;}
.calendar-nav{display:flex;align-items:center;gap:14px;}
.calendar-arrow{background:transparent;color:var(--g4);font-size:34px;padding:0 4px;}
.calendar-month{font-size:22px;font-weight:800;color:var(--g4);}
.calendar-action{background:var(--g4);color:var(--b0);padding:11px 16px;border-radius:12px;font-weight:800;transition:background .18s;}
.calendar-action:hover{background:var(--g5);color:#fff;}
.calendar-grid{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));gap:8px;}
.calendar-weekday{font-size:13px;font-weight:700;color:var(--g4);padding-bottom:4px;text-align:center;}
.calendar-day{min-height:82px;padding:9px;border-radius:16px;display:flex;flex-direction:column;align-items:flex-start;justify-content:space-between;gap:4px;background:rgba(255,255,255,.05);border:1px solid transparent;color:rgba(255,255,255,.85);text-align:left;}
.calendar-day.empty{visibility:hidden;}
.calendar-day.selected{background:rgba(46,204,90,.18);border-color:var(--g4);}
.calendar-day.today .day-number{color:var(--g4);}
.day-number{font-size:18px;font-weight:800;line-height:1;}
.day-badge{min-width:24px;height:24px;padding:0 6px;border-radius:999px;background:var(--g4);color:var(--b0);display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;align-self:flex-end;}
.calendar-bottom{display:grid;grid-template-columns:minmax(300px,1fr) minmax(300px,1fr);gap:16px;}
.info-box{padding:18px;border-radius:16px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.13);}
.info-box-title{font-size:18px;font-weight:800;color:var(--g4);margin-bottom:12px;}
.day-tasks{display:flex;flex-direction:column;gap:10px;}
.day-task{width:100%;padding:12px 14px;border-radius:13px;background:rgba(255,255,255,.95);color:var(--b0);display:grid;grid-template-columns:auto minmax(0,1fr);gap:12px;align-items:start;text-align:left;}
.day-time{padding:5px 9px;border-radius:999px;background:var(--g4);color:var(--b0);font-size:12px;font-weight:800;white-space:nowrap;}
.day-task-title{font-size:15px;font-weight:800;margin-bottom:3px;}
.day-task-meta{font-size:12px;color:var(--b3);}
.empty-note{padding:14px;border-radius:12px;background:rgba(255,255,255,.07);color:rgba(255,255,255,.65);font-size:14px;}
.events{display:flex;flex-direction:column;gap:10px;}
.event-row{display:flex;align-items:center;gap:12px;font-size:15px;line-height:1.35;}
.event-dot{width:10px;height:10px;border-radius:999px;background:var(--g4);flex:0 0 auto;}

/* STATS */
.stats-layout{display:grid;grid-template-columns:minmax(240px,.8fr) minmax(0,1.2fr);gap:28px;}
.profile-card{padding-right:18px;border-right:1px solid rgba(255,255,255,.14);}
.profile-title,.stats-title{font-size:22px;font-weight:800;margin-bottom:16px;color:var(--g4);}
.profile-table{display:grid;grid-template-columns:auto 1fr;gap:12px 22px;font-size:16px;}
.profile-label{color:rgba(255,255,255,.6);}
.profile-value{color:#fff;font-weight:600;}
.stats-column{display:flex;flex-direction:column;gap:14px;}
.stat-card{padding:16px 18px;color:var(--b0);border-radius:16px;position:relative;overflow:hidden;border-left:4px solid var(--g4);}
.stat-card::after{content:'';position:absolute;top:0;right:0;width:60px;height:60px;border-radius:0 16px 0 60px;background:rgba(0,0,0,.03);}
.stat-card-title{font-size:13px;font-weight:700;color:var(--b3);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;}
.stat-card-main{display:grid;grid-template-columns:56px 1fr;gap:12px;align-items:center;}
.big-number{font-size:40px;font-weight:800;line-height:1;color:var(--b0);letter-spacing:-1px;}
.real-chart{width:100%;height:90px;min-width:0;overflow:hidden;}
.real-chart svg{display:block;}

/* INVITATIONS in profile */
.inv-card{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:14px;padding:14px 16px;margin-bottom:10px;}
.inv-card-title{font-size:15px;font-weight:800;color:#fff;margin-bottom:4px;}
.inv-card-sub{font-size:13px;color:rgba(255,255,255,.7);margin-bottom:10px;}
.inv-card-actions{display:flex;gap:8px;}
.inv-accept{padding:8px 14px;border-radius:9px;background:var(--g4);color:var(--b0);font-weight:800;font-size:13px;transition:background .15s;}
.inv-accept:hover{background:var(--g5);color:#fff;}
.inv-reject{padding:8px 14px;border-radius:9px;background:rgba(255,255,255,.15);color:rgba(255,255,255,.8);font-weight:700;font-size:13px;transition:background .15s;}
.inv-reject:hover{background:rgba(255,255,255,.25);}

/* MODALS */
.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.54);display:flex;align-items:center;justify-content:center;padding:20px;z-index:40;}
.modal{width:min(100%,560px);background:#fff;border-radius:24px;box-shadow:0 24px 80px rgba(0,0,0,.24);padding:22px;color:var(--b0);}
.modal-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px;}
.modal-title{font-size:22px;font-weight:800;}
.modal-close{width:38px;height:38px;border-radius:999px;background:var(--g2);font-size:20px;font-weight:700;color:var(--b0);transition:background .15s;}
.modal-close:hover{background:var(--g3);}
.modal-form{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;}
.modal-form .full{grid-column:1/-1;}
.modal-field{display:flex;flex-direction:column;gap:6px;}
.modal-field label{font-size:13px;font-weight:700;color:var(--b2);}
.modal-field input:not(.time-seg),.modal-field textarea,.modal-field select{width:100%;padding:11px 13px;border:1.5px solid var(--g2);border-radius:11px;background:#fff;outline:none;transition:border-color .18s;}
/* Voice input */
.voice-input-wrap{position:relative;display:flex;align-items:stretch;}
.voice-input-wrap input,.voice-input-wrap textarea{flex:1;padding-right:44px!important;}
.voice-btn{position:absolute;right:8px;top:50%;transform:translateY(-50%);width:30px;height:30px;border-radius:50%;background:var(--g2);color:var(--b2);font-size:15px;display:flex;align-items:center;justify-content:center;transition:background .15s,color .15s,box-shadow .15s;border:none;cursor:pointer;z-index:1;}
.voice-btn:hover{background:var(--g3);}
.voice-btn.listening{background:var(--g5);color:#fff;box-shadow:0 0 0 4px rgba(26,168,67,.25);animation:voice-pulse 1.2s infinite;}
.voice-btn.listening:hover{background:var(--g6);}
.voice-input-wrap textarea~.voice-btn{top:14px;transform:none;}
@keyframes voice-pulse{0%,100%{box-shadow:0 0 0 3px rgba(26,168,67,.25);}50%{box-shadow:0 0 0 7px rgba(26,168,67,.10);}}
.modal-field input:not(.time-seg):focus,.modal-field textarea:focus,.modal-field select:focus{border-color:var(--g4);}
.modal-field textarea{min-height:100px;resize:vertical;}
.modal-meta{font-size:13px;font-weight:700;color:var(--g5);margin-bottom:10px;}
.modal-actions{display:flex;justify-content:flex-end;gap:10px;margin-top:8px;}
.modal-secondary{padding:11px 16px;border-radius:11px;background:var(--g2);color:var(--b0);font-weight:700;transition:background .15s;}
.modal-secondary:hover{background:var(--g3);}
.modal-primary{padding:11px 16px;border-radius:11px;background:var(--g5);color:#fff;font-weight:800;transition:background .15s;}
.modal-primary:hover{background:var(--g6);}
.info-modal{width:min(100%,620px);max-height:82vh;overflow-y:auto;}
.info-modal h2{font-size:18px;font-weight:800;margin:18px 0 7px;color:var(--g5);}
.info-modal h2:first-of-type{margin-top:0;}
.info-modal p{font-size:14px;line-height:1.7;color:#333;margin:0 0 10px;}
.info-modal ul{padding-left:18px;margin:0 0 10px;}
.info-modal li{font-size:14px;line-height:1.65;color:#444;margin-bottom:5px;}

/* STATUSES */
.status-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:12px;font-weight:700;white-space:nowrap;}
.status-pending{background:#fff3cd;color:#856404;}
.status-progress{background:#cfe2ff;color:#0a58ca;}
.status-review{background:#f8d7da;color:#842029;}
.status-done{background:#d1e7dd;color:#0a3622;}
.status-rejected{background:#e2e3e5;color:#41464b;}
.status-overdue{background:#f8d7da;color:#842029;}
.task-card{position:relative;}
.task-status-row{margin-top:4px;}
.action-btn{padding:11px 18px;border-radius:11px;font-weight:800;font-size:14px;transition:background .15s,color .15s;}
.action-start{background:#0a58ca;color:#fff;}
.action-start:hover{background:#084298;}
.action-finish{background:var(--g5);color:#fff;}
.action-finish:hover{background:var(--g6);}
.modal-actions-top{margin-bottom:14px;display:flex;gap:10px;flex-wrap:wrap;align-items:center;}

/* FILE UPLOAD */
.file-upload-zone{border:2px dashed var(--g3);border-radius:12px;padding:14px 16px;text-align:center;cursor:pointer;transition:border-color .18s,background .18s;background:var(--g1);position:relative;}
.file-upload-zone:hover,.file-upload-zone.drag{border-color:var(--g4);background:#f0fff4;}
.file-upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.file-upload-label{font-size:13px;color:var(--b3);font-weight:600;pointer-events:none;}
.file-upload-label strong{color:var(--g5);}
.file-attached{display:flex;align-items:center;gap:10px;padding:9px 13px;border-radius:10px;background:#e4f7eb;border:1.5px solid var(--g4);font-size:13px;font-weight:700;color:var(--g6);}
.file-attached-remove{margin-left:auto;background:transparent;color:var(--b3);font-size:18px;padding:0 4px;line-height:1;}
.file-attached-remove:hover{color:#c0392b;}

/* TIME INPUTS */
.time-field-wrap{display:flex;flex-direction:column;gap:6px;}
.time-input-row{display:flex;gap:2px;align-items:center;}
.time-seg{width:48px;padding:10px 2px;border:1.5px solid var(--g2);border-radius:11px;background:#fff;font-size:15px;font-weight:700;text-align:center;outline:none;transition:border-color .18s,background .18s;-moz-appearance:textfield;appearance:textfield;}
.time-ai-row{display:flex;align-items:center;gap:8px;margin-top:2px;}
.time-ai-btn{background:var(--g1);border:1.5px solid var(--g4);color:var(--g6);font-weight:800;font-size:12px;padding:5px 10px;border-radius:8px;white-space:nowrap;cursor:pointer;transition:background .15s;}
.time-ai-btn:hover{background:var(--g2);}
.time-seg::-webkit-inner-spin-button,.time-seg::-webkit-outer-spin-button{-webkit-appearance:none;margin:0;}
.time-seg:focus{border-color:var(--g4);background:#f0fff4;}
.time-sep{font-weight:800;color:var(--b3);padding:0;font-size:17px;}
.time-range-sep{font-weight:800;color:var(--b4);padding:0 2px;font-size:15px;}

/* TASK CARD START BUTTON */
.task-card-inner{display:flex;flex-direction:column;gap:4px;width:100%;}
.task-card-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:6px;}
.task-start-btn{padding:6px 13px;border-radius:9px;background:#0a58ca;color:#fff;font-size:12px;font-weight:800;transition:background .15s;white-space:nowrap;}
.task-start-btn:hover{background:#084298;}

/* TEACHER UI */
.t-btn-primary{padding:11px 20px;border-radius:12px;background:var(--b0);color:#fff;font-weight:800;font-size:14px;transition:background .18s;display:inline-flex;align-items:center;gap:8px;}
.t-btn-primary:hover{background:var(--b1);}
.t-btn-green{padding:11px 20px;border-radius:12px;background:var(--g5);color:#fff;font-weight:800;font-size:14px;transition:background .18s;display:inline-flex;align-items:center;gap:8px;}
.t-btn-green:hover{background:var(--g6);}
.t-btn-ghost{padding:9px 16px;border-radius:10px;background:rgba(0,0,0,.07);color:var(--b1);font-weight:700;font-size:13px;transition:background .15s;}
.t-btn-ghost:hover{background:rgba(0,0,0,.13);}
.t-btn-danger{padding:9px 14px;border-radius:10px;background:#ffeaea;color:#c0392b;font-weight:700;font-size:13px;transition:background .15s;}
.t-btn-danger:hover{background:#ffd5d5;}
.t-btn-blue{padding:9px 14px;border-radius:10px;background:#e8f4ff;color:#0a58ca;font-weight:700;font-size:13px;transition:background .15s;}
.t-btn-blue:hover{background:#d0eaff;}
.t-section-header{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px;flex-wrap:wrap;}
.t-class-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
.t-class-card{background:#fff;border-radius:18px;padding:22px 20px;box-shadow:0 6px 20px rgba(0,0,0,.08);cursor:pointer;transition:transform .15s,box-shadow .15s;text-align:left;border:2px solid transparent;}
.t-class-card:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(0,0,0,.13);border-color:var(--g3);}
.t-class-icon{font-size:36px;margin-bottom:10px;}
.t-class-name{font-size:22px;font-weight:800;color:var(--b0);margin-bottom:4px;}
.t-class-subject{font-size:14px;color:var(--b3);font-weight:600;margin-bottom:12px;}
.t-class-meta{display:flex;gap:14px;flex-wrap:wrap;}
.t-class-badge{background:var(--g2);color:var(--g6);font-size:12px;font-weight:800;padding:4px 10px;border-radius:999px;}
.t-empty{text-align:center;padding:48px 24px;color:var(--b3);background:rgba(255,255,255,.6);border-radius:18px;}
.t-empty-icon{font-size:56px;margin-bottom:12px;}
.t-empty-text{font-size:18px;font-weight:700;margin-bottom:6px;color:var(--b2);}
.t-empty-sub{font-size:14px;}
.t-back-btn{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.6);border-radius:10px;padding:8px 14px;font-weight:700;font-size:14px;color:var(--b1);margin-bottom:16px;transition:background .15s;}
.t-back-btn:hover{background:rgba(255,255,255,.9);}
.t-student-list{display:flex;flex-direction:column;gap:10px;}
.t-student-row{background:#fff;border-radius:14px;padding:14px 18px;display:flex;align-items:center;gap:14px;box-shadow:0 4px 12px rgba(0,0,0,.07);cursor:pointer;transition:box-shadow .15s;text-align:left;}
.t-student-row:hover{box-shadow:0 8px 20px rgba(0,0,0,.12);}
.t-student-avatar{width:46px;height:46px;border-radius:999px;background:var(--g4);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:var(--b0);flex:0 0 auto;}
.t-student-name{font-size:16px;font-weight:800;color:var(--b0);}
.t-student-meta{font-size:13px;color:var(--b3);margin-top:2px;}
.t-student-stats{margin-left:auto;display:flex;gap:10px;}
.t-mini-stat{text-align:center;}
.t-mini-num{font-size:20px;font-weight:800;color:var(--b0);line-height:1;}
.t-mini-lbl{font-size:10px;font-weight:700;color:var(--b3);}
.t-stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:22px;}
.t-stat-box{background:#fff;border-radius:16px;padding:18px 16px;box-shadow:0 4px 14px rgba(0,0,0,.08);}
.t-stat-num{font-size:40px;font-weight:800;color:var(--b0);line-height:1;}
.t-stat-lbl{font-size:13px;font-weight:700;color:var(--b3);margin-top:4px;}
.t-bar-wrap{display:flex;flex-direction:column;gap:8px;}
.t-bar-row{display:flex;align-items:center;gap:10px;font-size:13px;}
.t-bar-name{width:130px;font-weight:700;color:var(--b1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.t-bar-track{flex:1;height:10px;border-radius:999px;background:var(--g2);overflow:hidden;}
.t-bar-fill{height:100%;border-radius:999px;background:var(--g4);transition:width .4s;}
.t-bar-count{font-weight:800;color:var(--b0);min-width:28px;text-align:right;}
.t-profile-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:16px;}
.t-profile-box{background:var(--g1);border-radius:12px;padding:12px 14px;}
.t-profile-lbl{font-size:11px;font-weight:700;color:var(--b3);text-transform:uppercase;letter-spacing:.5px;}
.t-profile-val{font-size:17px;font-weight:800;color:var(--b0);margin-top:4px;}
.t-task-mini{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;background:var(--g1);margin-bottom:6px;font-size:13px;}
.t-task-done{opacity:.55;text-decoration:line-through;}
.t-task-dot{width:10px;height:10px;border-radius:999px;background:var(--g4);flex:0 0 auto;}
.t-task-dot.overdue{background:#e74c3c;}
.t-task-dot.done{background:var(--b3);}
.t-class-header{background:#fff;border-radius:16px;padding:20px 22px;margin-bottom:20px;box-shadow:0 4px 14px rgba(0,0,0,.07);display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
.t-tab-row{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;}
.t-tab{padding:9px 18px;border-radius:10px;font-weight:700;font-size:14px;background:rgba(255,255,255,.5);color:var(--b2);transition:background .15s,color .15s;}
.t-tab.active{background:var(--b0);color:#fff;}
/* Prediction hint */
.ai-hint{font-size:13px;color:var(--g5);font-weight:700;opacity:0;transition:opacity .3s ease;position:absolute;left:0;top:100%;margin-top:6px;white-space:nowrap;pointer-events:none;z-index:10;background:#fff;padding:4px 10px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.12);border:1.5px solid var(--g4);}
.ai-hint.visible{opacity:1;}
.ai-predict-wrap{position:relative;display:flex;align-items:center;gap:6px;flex-shrink:0;margin-bottom:4px;}
/* Review task card */
.review-card{background:#fff;border-radius:14px;padding:16px 18px;box-shadow:0 4px 14px rgba(0,0,0,.08);margin-bottom:10px;display:flex;align-items:flex-start;gap:14px;flex-wrap:wrap;}
.review-card-info{flex:1;min-width:0;}
.review-card-title{font-size:16px;font-weight:800;color:var(--b0);margin-bottom:4px;}
.review-card-meta{font-size:13px;color:var(--b3);margin-bottom:8px;}
.review-card-actions{display:flex;gap:8px;margin-top:4px;flex-wrap:wrap;}


/* AI TEST MODAL */
.ai-test-modal{width:min(100%,720px);max-height:90vh;overflow-y:auto;}
.ai-test-header{display:flex;align-items:center;gap:12px;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid var(--g2);}
.ai-test-icon{font-size:32px;}
.ai-test-title{font-size:22px;font-weight:800;color:var(--b0);}
.ai-test-sub{font-size:13px;color:var(--b3);margin-top:2px;}
.ai-loading{display:flex;flex-direction:column;align-items:center;gap:16px;padding:40px 20px;text-align:center;}
.ai-spinner{width:48px;height:48px;border:4px solid var(--g2);border-top-color:var(--g4);border-radius:999px;animation:aiSpin 1s linear infinite;}
@keyframes aiSpin{to{transform:rotate(360deg);}}
.ai-loading-text{font-size:16px;font-weight:700;color:var(--b2);}
.ai-loading-sub{font-size:13px;color:var(--b3);max-width:320px;line-height:1.5;}

/* Question card */
.ai-question-card{background:#f8faf8;border-radius:16px;padding:20px 22px;margin-bottom:14px;border:1.5px solid var(--g2);}
.ai-question-num{font-size:13px;font-weight:800;color:var(--g5);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.ai-question-text{font-size:16px;font-weight:700;color:var(--b0);margin-bottom:14px;line-height:1.5;}
.ai-options{display:flex;flex-direction:column;gap:8px;}
.ai-option{display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:11px;background:#fff;border:2px solid var(--g2);cursor:pointer;transition:all .15s;font-size:15px;font-weight:600;color:var(--b1);}
.ai-option:hover{border-color:var(--g3);background:var(--g1);}
.ai-option.selected{border-color:var(--g4);background:#e4f7eb;color:var(--g6);}
.ai-option.correct{border-color:var(--g4);background:#d1e7dd;color:#0a3622;}
.ai-option.wrong{border-color:#e74c3c;background:#f8d7da;color:#842029;}
.ai-option-letter{width:28px;height:28px;border-radius:999px;background:var(--g2);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:var(--b0);flex-shrink:0;}
.ai-option.selected .ai-option-letter,.ai-option.correct .ai-option-letter{background:var(--g4);color:#fff;}
.ai-option.wrong .ai-option-letter{background:#e74c3c;color:#fff;}

/* Test results */
.ai-results{text-align:center;padding:24px 20px;}
.ai-results-score{font-size:64px;font-weight:800;color:var(--g5);line-height:1;}
.ai-results-label{font-size:16px;font-weight:700;color:var(--b2);margin-top:8px;}
.ai-results-detail{font-size:14px;color:var(--b3);margin-top:6px;}
.ai-mistakes{margin-top:20px;text-align:left;}
.ai-mistake-item{background:#fff3e8;border-radius:12px;padding:14px 16px;margin-bottom:10px;border-left:4px solid #b85c00;}
.ai-mistake-q{font-size:14px;font-weight:700;color:var(--b0);margin-bottom:6px;}
.ai-mistake-a{font-size:13px;color:var(--b3);line-height:1.5;}
.ai-mistake-correct{color:var(--g5);font-weight:700;}

/* Explain modal */
.ai-explain-modal{width:min(100%,640px);max-height:88vh;overflow-y:auto;}
.ai-explain-content{font-size:15px;line-height:1.8;color:var(--b1);}
.ai-explain-content h3{font-size:18px;font-weight:800;color:var(--g5);margin:20px 0 10px;}
.ai-explain-content p{margin:0 0 12px;}
.ai-explain-content ul{padding-left:20px;margin:0 0 12px;}
.ai-explain-content li{margin-bottom:6px;}
.ai-explain-content code{background:var(--g1);padding:2px 6px;border-radius:4px;font-size:13px;font-family:monospace;}
.ai-explain-content pre{background:var(--g1);padding:12px 14px;border-radius:10px;overflow-x:auto;font-size:13px;line-height:1.6;margin:10px 0;}
.ai-chat-box{margin-top:16px;padding-top:16px;border-top:1.5px solid var(--g2);}
.ai-chat-input-row{display:flex;gap:8px;}
.ai-chat-input{flex:1;padding:10px 14px;border:1.5px solid var(--g2);border-radius:11px;font-size:14px;outline:none;}
.ai-chat-input:focus{border-color:var(--g4);}
.ai-chat-send{padding:10px 16px;border-radius:11px;background:var(--g5);color:#fff;font-weight:700;font-size:14px;border:0;cursor:pointer;transition:background .15s;}
.ai-chat-send:hover{background:var(--g6);}
.ai-chat-history{max-height:200px;overflow-y:auto;margin-bottom:12px;display:flex;flex-direction:column;gap:8px;}
.ai-chat-msg{padding:10px 14px;border-radius:12px;font-size:14px;line-height:1.5;max-width:90%;}
.ai-chat-msg.user{align-self:flex-end;background:var(--g4);color:var(--b0);font-weight:600;}
.ai-chat-msg.bot{align-self:flex-start;background:var(--g1);color:var(--b1);border:1px solid var(--g2);}

/* Error message for non-topic tasks */
.ai-error-box{text-align:center;padding:40px 24px;}
.ai-error-icon{font-size:56px;margin-bottom:16px;}
.ai-error-title{font-size:20px;font-weight:800;color:var(--b0);margin-bottom:8px;}
.ai-error-text{font-size:14px;color:var(--b3);line-height:1.6;max-width:360px;margin:0 auto;}

/* AI action buttons in view modal */
.ai-actions-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}
.ai-action-btn{padding:8px 14px;border-radius:10px;font-size:13px;font-weight:700;border:1.5px solid var(--g3);background:#fff;color:var(--g6);cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.ai-action-btn:hover{background:var(--g1);border-color:var(--g4);}
.ai-action-btn:disabled{opacity:.5;cursor:not-allowed;}

@media(max-width:1100px){
	.layout{grid-template-columns:1fr;}
	.sidebar{flex-direction:row;min-height:auto;gap:14px;}
	.side-stack{flex-direction:row;justify-content:space-around;}
	.side-footer{display:none;}
	.stats-layout,.calendar-bottom{grid-template-columns:1fr;}
	.profile-card{border-right:0;border-bottom:1px solid rgba(255,255,255,.14);padding-right:0;padding-bottom:16px;}
}
@media(max-width:760px){
	.shell{padding:10px;border-radius:18px;}
	.screen{padding:16px 14px;}
	.calendar-toolbar{flex-direction:column;align-items:flex-start;}
	.task-card{grid-template-columns:auto 1fr;}
	.task-deadline{grid-column:2;}
	.profile-table{grid-template-columns:1fr;gap:8px;}
	.calendar-grid{gap:6px;}
	.calendar-day{min-height:68px;}
	.modal-form{grid-template-columns:1fr;}
}

/* ═══════════════════════════════════════
   PARENT INTERFACE STYLES
════════════════════════════════════════ */
.p-layout{display:grid;grid-template-columns:minmax(0,1fr) 132px;gap:12px;min-height:calc(100vh - 110px);}
.p-screen{min-height:100%;border-radius:var(--rx);padding:22px 24px;overflow:hidden;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff;}
.p-screen h1{margin:0 0 16px;font-size:clamp(30px,4vw,44px);line-height:1.02;font-weight:800;}
.p-section-title{margin:20px 0 12px;font-size:20px;font-weight:700;color:rgba(255,255,255,.8);}
.p-card{background:rgba(255,255,255,.95);border-radius:18px;padding:22px 20px;box-shadow:0 6px 20px rgba(0,0,0,.12);color:var(--b0);cursor:pointer;transition:transform .15s,box-shadow .15s;text-align:left;border:2px solid transparent;}
.p-card:hover{transform:translateY(-3px);box-shadow:0 14px 32px rgba(0,0,0,.18);border-color:rgba(118,75,162,.3);}
.p-card-avatar{width:56px;height:56px;border-radius:999px;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:800;color:#fff;flex:0 0 auto;}
.p-card-info{flex:1;min-width:0;}
.p-card-name{font-size:18px;font-weight:800;color:var(--b0);margin-bottom:3px;}
.p-card-meta{font-size:13px;color:var(--b3);}
.p-card-stats{display:flex;gap:14px;margin-left:auto;}
.p-mini-stat{text-align:center;}
.p-mini-num{font-size:22px;font-weight:800;color:var(--b0);line-height:1;}
.p-mini-lbl{font-size:10px;font-weight:700;color:var(--b3);text-transform:uppercase;}
.p-empty{text-align:center;padding:48px 24px;color:rgba(255,255,255,.7);background:rgba(255,255,255,.1);border-radius:18px;border:2px dashed rgba(255,255,255,.25);}
.p-empty-icon{font-size:56px;margin-bottom:12px;}
.p-empty-text{font-size:20px;font-weight:700;margin-bottom:6px;color:#fff;}
.p-empty-sub{font-size:14px;opacity:.8;}
.p-btn-primary{padding:12px 22px;border-radius:14px;background:#fff;color:#764ba2;font-weight:800;font-size:15px;transition:transform .15s,box-shadow .15s;display:inline-flex;align-items:center;gap:10px;border:0;box-shadow:0 4px 14px rgba(0,0,0,.15);cursor:pointer;}
.p-btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.2);}
.p-btn-ghost{padding:10px 18px;border-radius:12px;background:rgba(255,255,255,.15);color:#fff;font-weight:700;font-size:14px;transition:background .15s;border:1.5px solid rgba(255,255,255,.3);cursor:pointer;}
.p-btn-ghost:hover{background:rgba(255,255,255,.25);}
.p-header-bar{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:20px;flex-wrap:wrap;}
.p-child-detail-header{display:flex;align-items:center;gap:16px;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid rgba(255,255,255,.2);flex-wrap:wrap;}
.p-child-detail-avatar{width:72px;height:72px;border-radius:999px;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:800;color:#fff;}
.p-child-detail-info{flex:1;min-width:0;}
.p-child-detail-name{font-size:28px;font-weight:800;color:#fff;margin-bottom:4px;}
.p-child-detail-meta{font-size:15px;color:rgba(255,255,255,.75);}
.p-stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:24px;}
.p-stat-box{background:rgba(255,255,255,.95);border-radius:16px;padding:18px 16px;color:var(--b0);box-shadow:0 4px 14px rgba(0,0,0,.1);}
.p-stat-num{font-size:36px;font-weight:800;color:#764ba2;line-height:1;}
.p-stat-lbl{font-size:13px;font-weight:700;color:var(--b3);margin-top:4px;}
.p-tasks-list{display:flex;flex-direction:column;gap:10px;}
.p-task-row{background:rgba(255,255,255,.95);border-radius:14px;padding:14px 18px;display:flex;align-items:center;gap:14px;color:var(--b0);box-shadow:0 4px 12px rgba(0,0,0,.08);cursor:pointer;transition:box-shadow .15s;text-align:left;border:0;width:100%;}
.p-task-row:hover{box-shadow:0 8px 20px rgba(0,0,0,.14);}
.p-task-dot{width:12px;height:12px;border-radius:999px;background:var(--g4);flex:0 0 auto;}
.p-task-dot.done{background:var(--b3);}
.p-task-dot.overdue{background:#e74c3c;}
.p-task-dot.pending{background:#f39c12;}
.p-task-info{flex:1;min-width:0;}
.p-task-title{font-size:15px;font-weight:800;margin-bottom:2px;}
.p-task-meta{font-size:12px;color:var(--b3);}
.p-task-date{font-size:13px;font-weight:700;color:var(--b2);white-space:nowrap;}
.p-back-btn{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.2);border-radius:10px;padding:8px 14px;font-weight:700;font-size:14px;color:#fff;margin-bottom:16px;transition:background .15s;border:0;cursor:pointer;}
.p-back-btn:hover{background:rgba(255,255,255,.35);}
.p-calendar-grid{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));gap:8px;}
.p-calendar-day{min-height:70px;padding:8px;border-radius:14px;display:flex;flex-direction:column;align-items:flex-start;justify-content:space-between;gap:4px;background:rgba(255,255,255,.1);border:1px solid transparent;color:rgba(255,255,255,.85);text-align:left;cursor:pointer;}
.p-calendar-day.empty{visibility:hidden;}
.p-calendar-day.selected{background:rgba(255,255,255,.25);border-color:rgba(255,255,255,.4);}
.p-calendar-day.today .p-day-number{color:#ffd700;font-weight:900;}
.p-day-number{font-size:16px;font-weight:800;line-height:1;}
.p-day-badge{min-width:22px;height:22px;padding:0 6px;border-radius:999px;background:#ffd700;color:#764ba2;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;align-self:flex-end;}
.p-calendar-weekday{font-size:13px;font-weight:700;color:rgba(255,255,255,.7);padding-bottom:4px;text-align:center;}
.p-calendar-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;}
.p-calendar-nav{display:flex;align-items:center;gap:14px;}
.p-calendar-arrow{background:transparent;color:#ffd700;font-size:34px;padding:0 4px;border:0;cursor:pointer;}
.p-calendar-month{font-size:22px;font-weight:800;color:#fff;}
.p-calendar-action{background:#fff;color:#764ba2;padding:11px 16px;border-radius:12px;font-weight:800;transition:transform .15s;border:0;box-shadow:0 4px 14px rgba(0,0,0,.15);cursor:pointer;}
.p-calendar-action:hover{transform:translateY(-2px);}
.p-info-box{padding:18px;border-radius:16px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);}
.p-info-title{font-size:18px;font-weight:800;color:#ffd700;margin-bottom:12px;}
.p-day-tasks{display:flex;flex-direction:column;gap:10px;}
.p-day-task{width:100%;padding:12px 14px;border-radius:13px;background:rgba(255,255,255,.95);color:var(--b0);display:grid;grid-template-columns:auto minmax(0,1fr);gap:12px;align-items:start;text-align:left;border:0;cursor:pointer;}
.p-day-time{padding:5px 9px;border-radius:999px;background:#667eea;color:#fff;font-size:12px;font-weight:800;white-space:nowrap;}
.p-profile-card{background:rgba(255,255,255,.1);border-radius:18px;padding:22px;border:1px solid rgba(255,255,255,.2);}
.p-profile-title{font-size:20px;font-weight:800;color:#ffd700;margin-bottom:16px;}
.p-profile-table{display:grid;grid-template-columns:auto 1fr;gap:12px 22px;font-size:16px;color:#fff;}
.p-profile-label{color:rgba(255,255,255,.6);}
.p-profile-value{color:#fff;font-weight:600;}
.p-invite-result{font-size:14px;font-weight:600;padding:10px 14px;border-radius:10px;display:none;margin-top:10px;}
.p-child-remove{position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:999px;background:rgba(255,255,255,.9);color:#c0392b;border:0;font-size:16px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s;}
.p-child-remove:hover{background:#fff;}
.p-card-wrap{position:relative;}
@media(max-width:700px){
  .p-layout{grid-template-columns:1fr;}
  .p-stats-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));}
  .p-screen{padding:16px 14px;}
  .p-child-detail-header{flex-direction:column;align-items:flex-start;}
  .p-header-bar{flex-direction:column;align-items:stretch;}
  .p-card-stats{width:100%;justify-content:space-around;margin-left:0;margin-top:10px;}
  .p-calendar-grid{gap:6px;}
}
</style>
<base target="_blank">
<base target="_blank">
<base target="_blank">
</head>
<body>

<!-- ═══════ AUTH ═══════ -->
<div id="authScreen" class="auth-wrap">
<div class="auth-card">
<div class="auth-brand">School<span>Plan</span></div>
<div class="auth-sub">Планировщик для школьников</div>
<div class="auth-tabs">
	<button class="auth-tab active" id="tabLogin" type="button">Войти</button>
	<button class="auth-tab" id="tabReg" type="button">Регистрация</button>
</div>
<div id="loginForm">
	<div id="loginError" class="auth-error" hidden></div>
	<div class="auth-field"><label>Логин</label><input id="loginUsername" type="text" placeholder="Ваш логин" autocomplete="username"/></div>
	<div class="auth-field"><label>Пароль</label><input id="loginPassword" type="password" placeholder="Ваш пароль" autocomplete="current-password"/></div>
	<button class="auth-submit" id="doLogin" type="button">Войти</button>
</div>
<div id="registerForm" hidden>
	<div id="regError" class="auth-error" hidden></div>
	<div class="auth-field"><label>Логин</label><input id="regUsername" type="text" placeholder="Придумайте логин" autocomplete="off"/></div>
	<div class="auth-field"><label>Пароль</label><input id="regPassword" type="password" placeholder="Придумайте пароль" autocomplete="new-password"/></div>
	<div class="auth-field"><label>Повторите пароль</label><input id="regPassword2" type="password" placeholder="Повторите пароль" autocomplete="new-password"/></div>
	<div class="two-col">
		<div class="auth-field"><label>Имя</label><input id="regName" type="text" placeholder="Ваше имя"/></div>
		<div class="auth-field"><label>Фамилия</label><input id="regSurname" type="text" placeholder="Ваша фамилия"/></div>
	</div>
	<div class="auth-field" style="margin-bottom:8px"><label>Кто вы?</label></div>
	<div class="role-grid">
		<button class="role-btn" data-role="student" type="button"><span class="role-icon">🎒</span><span>Ученик</span></button>
		<button class="role-btn" data-role="teacher" type="button"><span class="role-icon">📚</span><span>Учитель</span></button>
		<button class="role-btn" data-role="parent"  type="button"><span class="role-icon">👨‍👩‍👧</span><span>Родитель</span></button>
	</div>
	<div id="schoolField" class="auth-field" hidden><label>Школа</label><input id="regSchool" type="text" placeholder="Например, Школа №42"/></div>
	<button class="auth-submit" id="doRegister" type="button">Зарегистрироваться</button>
</div>
</div>
</div>

<!-- ═══════ STUDENT APP ═══════ -->
<div id="appScreen" hidden class="app">
<div class="shell">
<header class="topbar">
	<div class="brand">School<em>Plan</em></div>
	<button class="topbar-btn" id="logoutBtn" type="button"><span>↪</span><span>Выход</span></button>
</header>
<div class="layout">
	<main id="screen-tasks" class="screen tasks">
		<h1>Задания</h1>
		<div class="section-title">Ближайшие задания</div>
		<div id="nearestTasks" class="tasks-group"></div>
		<div class="add-box">
			<div class="section-title">Добавить задачу</div>
			<button class="add-trigger card-white" id="addTaskFromTasks" type="button">
				<span class="add-icon">+</span>
				<span class="add-text">Открыть календарь и создать задачу</span>
			</button>
		</div>
	</main>
	<main id="screen-calendar" class="screen calendar" hidden>
		<h1>Календарь</h1>
		<div class="calendar-layout">
			<section>
				<div class="calendar-toolbar">
					<div class="calendar-nav">
						<button class="calendar-arrow" id="prevMonth" type="button">‹</button>
						<div id="calendarMonthLabel" class="calendar-month"></div>
						<button class="calendar-arrow" id="nextMonth" type="button">›</button>
					</div>
					<button class="calendar-action" id="openCreateModal" type="button">+ Добавить задачу</button>
				</div>
				<div id="calendarGrid" class="calendar-grid"></div>
			</section>
			<div class="calendar-bottom">
				<div class="info-box">
					<div class="info-box-title">Задачи на день</div>
					<div id="selectedDateLabel" class="section-title" style="margin-top:0;font-size:15px"></div>
					<div id="selectedDayTasks" class="day-tasks"></div>
				</div>
				<div class="info-box">
					<div class="info-box-title">Ближайшие события</div>
					<div id="upcomingEvents" class="events"></div>
				</div>
			</div>
		</div>
	</main>
	<main id="screen-stats" class="screen stats" hidden>
		<div class="stats-layout">
			<section class="profile-card">
				<div class="profile-title">Личный кабинет</div>
				<div class="profile-table">
					<div class="profile-label">Имя</div>       <div class="profile-value" id="profileName">—</div>
					<div class="profile-label">Фамилия</div>   <div class="profile-value" id="profileSurname">—</div>
					<div class="profile-label">Логин</div>     <div class="profile-value" id="profileLogin">—</div>
					<div class="profile-label">Роль</div>      <div class="profile-value" id="profileRole">—</div>
					<div class="profile-label">Школа</div>     <div class="profile-value" id="profileSchool">—</div>
					<div class="profile-label">ID</div>        <div class="profile-value" id="profileId">—</div>
				</div>
				<!-- Приглашения -->
				<div id="invitationsSection" style="margin-top:20px">
					<div class="profile-title" style="font-size:17px;margin-bottom:10px">📬 Приглашения</div>
					<div id="invitationsList"></div>
				</div>
				<!-- AI Советы -->
				<div style="margin-top:24px">
					<div class="profile-title" style="font-size:17px;margin-bottom:10px">🤖 ИИ-наставник</div>
					<button id="aiAdviceBtn" type="button" style="width:100%;padding:12px 16px;border-radius:13px;background:linear-gradient(135deg,#1aa843,#0f7a30);color:#fff;font-weight:800;font-size:14px;border:0;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:opacity .15s;">
						<span>✨</span><span>Получить советы</span>
					</button>
					<div id="aiAdviceBlock" style="display:none;margin-top:14px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:14px;padding:14px 16px;max-height:240px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.25) transparent;">
						<div id="aiAdviceContent" style="font-size:14px;line-height:1.7;color:#fff;"></div>
					</div>
				</div>
			</section>
			<section>
				<div class="stats-title">Статистика</div>
				<div class="stats-column">
					<div class="stat-card card-white">
						<div class="stat-card-title">✅ Выполненные задания</div>
						<div class="stat-card-main"><div class="big-number" id="doneCount">0</div><div id="doneChart" class="real-chart"></div></div>
					</div>
					<div class="stat-card card-white">
						<div class="stat-card-title">⏳ Задания в работе</div>
						<div class="stat-card-main"><div class="big-number" id="workCount">0</div><div id="workChart" class="real-chart"></div></div>
					</div>
					<div class="stat-card card-white" style="border-left:4px solid #c0392b;">
						<div class="stat-card-title">⚠️ Просроченные задания</div>
						<div class="stat-card-main"><div class="big-number" id="overdueCount" style="color:#c0392b">0</div><div id="overdueChart" class="real-chart"></div></div>
					</div>
					<div class="stat-card card-white" style="border-left:4px solid #e67e22;">
						<div class="stat-card-title">❌ Отклонённые задания</div>
						<div class="stat-card-main"><div class="big-number" id="rejectedCount" style="color:#e67e22">0</div><div id="rejectedChart" class="real-chart"></div></div>
					</div>
				</div>
			</section>
		</div>
	</main>
	<aside class="sidebar">
		<div class="side-stack">
			<button class="side-item" data-screen="calendar" type="button">
				<span class="side-circle bk">🗓</span>
				<span class="side-label">Календарь</span>
			</button>
			<button class="side-item active" data-screen="tasks" type="button">
				<span class="side-circle g">📋</span>
				<span class="side-label">Задания</span>
			</button>
			<button class="side-item" data-screen="stats" type="button" id="profileSideBtn">
				<span class="side-circle dg">👤</span>
				<span class="side-label">Кабинет</span>
				<span class="side-badge" id="invBadge" hidden>!</span>
			</button>
		</div>
		<div class="side-footer">
			<button class="side-footer-btn" id="openAboutModal" type="button">О нас</button>
			<button class="side-footer-btn" id="openTermsModal" type="button">Пользовательское соглашение</button>
		</div>
	</aside>
</div>
</div>
</div>

<!-- ═══════ TEACHER APP ═══════ -->
<div id="teacherScreen" hidden class="app">
<div class="shell">
<header class="topbar">
	<div class="brand">School<em>Plan</em> <span style="font-size:14px;font-weight:600;color:var(--g5);background:var(--g2);padding:3px 10px;border-radius:8px;margin-left:6px;">Учитель</span></div>
	<button class="topbar-btn" id="teacherLogoutBtn" type="button"><span>↪</span><span>Выход</span></button>
</header>
<div class="layout">
	<main id="t-screen-main" class="screen tasks" style="min-height:calc(100vh - 110px)">
		<h1 id="teacherScreenTitle">Мои классы</h1>
		<div id="teacherContent"></div>
	</main>
	<aside class="sidebar">
		<div class="side-stack">
			<button class="side-item active" data-tscreen="classes" type="button">
				<span class="side-circle g">🏫</span>
				<span class="side-label">Классы</span>
			</button>
			<button class="side-item" data-tscreen="review" type="button" id="reviewSideBtn">
				<span class="side-circle bk">📥</span>
				<span class="side-label">Проверка</span>
				<span class="side-badge" id="reviewBadge" hidden>0</span>
			</button>
			<button class="side-item" data-tscreen="stats" type="button">
				<span class="side-circle bk">📊</span>
				<span class="side-label">Статистика</span>
			</button>
			<button class="side-item" data-tscreen="profile" type="button">
				<span class="side-circle dg">👤</span>
				<span class="side-label">Кабинет</span>
			</button>
		</div>
		<div class="side-footer">
			<div style="font-size:11px;font-weight:700;color:var(--b3);text-align:center;padding:4px 0" id="teacherSideId"></div>
		</div>
	</aside>
</div>
</div>
</div>

<!-- ═══════ PARENT SCREEN ═══════ -->
<div id="parentScreen" hidden class="app">
<div class="shell">
<header class="topbar">
    <div class="brand">School<em>Plan</em> <span style="font-size:14px;font-weight:600;color:#764ba2;background:rgba(118,75,162,.15);padding:3px 10px;border-radius:8px;margin-left:6px;">Родитель</span></div>
    <button class="topbar-btn" id="parentLogoutBtn" type="button"><span>↪</span><span>Выход</span></button>
</header>
<div class="p-layout">
    <main id="p-screen-main" class="p-screen" style="min-height:calc(100vh - 110px)">
        <h1 id="parentScreenTitle">Мои дети</h1>
        <div id="parentContent"></div>
    </main>
    <aside class="sidebar" style="background:linear-gradient(180deg,#667eea 0%,#764ba2 100%);">
        <div class="side-stack">
            <button class="side-item active" data-pscreen="children" type="button">
                <span class="side-circle" style="background:#fff;color:#764ba2;">👨‍👩‍👧</span>
                <span class="side-label" style="color:#fff;">Дети</span>
            </button>
            <button class="side-item" data-pscreen="calendar" type="button">
                <span class="side-circle" style="background:rgba(255,255,255,.2);color:#fff;">🗓</span>
                <span class="side-label" style="color:#fff;">Календарь</span>
            </button>
            <button class="side-item" data-pscreen="profile" type="button">
                <span class="side-circle" style="background:rgba(255,255,255,.2);color:#fff;">👤</span>
                <span class="side-label" style="color:#fff;">Кабинет</span>
            </button>
        </div>
        <div class="side-footer">
            <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,.7);text-align:center;padding:4px 0" id="parentSideId"></div>
        </div>
    </aside>
</div>
</div>
</div>

<!-- Modal: Parent Add Child -->
<div id="addChildModal" class="modal-backdrop" hidden>
<div class="modal" role="dialog">
<div class="modal-head"><div class="modal-title">Добавить ребёнка</div><button class="modal-close" id="closeAddChildModal" type="button">×</button></div>
<div style="display:flex;flex-direction:column;gap:14px">
    <div style="font-size:13px;color:var(--b3);line-height:1.5">Введите ID ребёнка. Ребёнок найдёт свой ID в разделе «Кабинет» → поле «ID». После добавления вы сможете видеть его задания и создавать для него новые.</div>
    <div class="modal-field"><label>ID ребёнка</label><input id="addChildId" placeholder="Например, 3847291" type="number"/></div>
    <div id="addChildResult" class="p-invite-result"></div>
    <div class="modal-actions">
        <button class="modal-secondary" id="cancelAddChildModal" type="button">Отмена</button>
        <button class="modal-primary" id="doAddChild" type="button">Добавить</button>
    </div>
</div>
</div>
</div>

<!-- Modal: Parent Create Task for Child -->
<div id="parentTaskModal" class="modal-backdrop" hidden>
<div class="modal" role="dialog" aria-modal="true">
<div class="modal-head"><div class="modal-title">Задание для ребёнка</div><button class="modal-close" id="closeParentTaskModal" type="button">×</button></div>
<form id="parentTaskForm" class="modal-form">
    <div id="parentTaskError" class="auth-error full" hidden></div>
    <div class="modal-field full"><label>Ребёнок</label><select id="parentTaskChildSelect"></select></div>
    <div class="modal-field full"><label>Название</label><div class="voice-input-wrap"><input id="parentTaskName" name="title" placeholder="Например, прочитать книгу" required/><button type="button" class="voice-btn" data-target="parentTaskName" title="Голосовой ввод">🎤</button></div></div>
    <div class="modal-field"><label>Дата</label><input id="parentTaskDate" name="date" type="date" required/></div>
    <div class="modal-field time-field-wrap">
        <label>Время (начало–конец)</label>
        <div class="time-input-row">
            <input class="time-seg" id="parentStartH" type="number" min="0" max="23" placeholder="ЧЧ"/>
            <span class="time-sep">:</span>
            <input class="time-seg" id="parentStartM" type="number" min="0" max="59" placeholder="ММ"/>
            <span class="time-range-sep">–</span>
            <input class="time-seg" id="parentEndH" type="number" min="0" max="23" placeholder="ЧЧ"/>
            <span class="time-sep">:</span>
            <input class="time-seg" id="parentEndM" type="number" min="0" max="59" placeholder="ММ"/>
        </div>
        <div class="time-ai-row">
            <button class="time-ai-btn" type="button" id="predictParentBtn">🤖 AI — предсказать время</button>
            <span id="predictParentHint" style="font-size:12px;color:var(--g5);font-weight:700;"></span>
        </div>
    </div>
    <div class="modal-field full"><label>Описание</label><div class="voice-input-wrap"><textarea id="parentTaskDesc" name="desc" placeholder="Что нужно сделать" required></textarea><button type="button" class="voice-btn" data-target="parentTaskDesc" title="Голосовой ввод">🎤</button></div></div>
    <div class="modal-actions full">
        <button class="modal-secondary" id="cancelParentTaskModal" type="button">Отмена</button>
        <button class="modal-primary" type="submit">Создать задание</button>
    </div>
</form>
</div>
</div>

<!-- Modal: Parent View Child Task -->
<div id="parentViewTaskModal" class="modal-backdrop" hidden>
<div class="modal" role="dialog" aria-modal="true">
<div class="modal-head"><div class="modal-title">Задание ребёнка</div><button class="modal-close" id="closeParentViewTaskModal" type="button">×</button></div>
<div id="parentViewTaskContent" style="display:flex;flex-direction:column;gap:14px">
    <div id="parentViewTaskStatus" style="margin-bottom:4px"></div>
    <div class="modal-field full"><label>Название</label><input id="parentViewTaskName" readonly style="background:var(--g1)"/></div>
    <div class="modal-field"><label>Дата</label><input id="parentViewTaskDate" readonly style="background:var(--g1)"/></div>
    <div class="modal-field"><label>Время</label><input id="parentViewTaskTime" readonly style="background:var(--g1)"/></div>
    <div class="modal-field full"><label>Описание</label><textarea id="parentViewTaskDesc" readonly style="background:var(--g1);min-height:80px"></textarea></div>
    <div id="parentViewTaskFileRow" class="full" style="display:none">
        <div style="font-size:13px;font-weight:700;color:var(--b2);margin-bottom:6px">📎 Файл от учителя</div>
        <div class="file-attached">
            <span>📄</span><span id="parentViewTaskFileName"></span>
            <a id="parentViewTaskFileLink" href="#" target="_blank" style="margin-left:auto;color:var(--g5);font-weight:700;font-size:13px;text-decoration:none">⬇ Скачать</a>
        </div>
    </div>
    <div id="parentViewStudentFileRow" class="full" style="display:none">
        <div style="font-size:13px;font-weight:700;color:var(--b2);margin-bottom:6px">📤 Работа ребёнка</div>
        <div class="file-attached">
            <span>📄</span><span id="parentViewStudentFileName"></span>
            <a id="parentViewStudentFileLink" href="#" target="_blank" style="margin-left:auto;color:var(--g5);font-weight:700;font-size:13px;text-decoration:none">⬇ Скачать</a>
        </div>
    </div>
    <div class="modal-actions">
        <div id="parentViewTaskActions" style="display:contents"></div>
        <button class="modal-secondary" id="closeParentViewTaskModalBtn" type="button">Закрыть</button>
    </div>
</div>
</div>
</div>

<!-- Modal: Create Task -->
<div id="createModal" class="modal-backdrop" hidden>
<div class="modal" role="dialog" aria-modal="true">
<div class="modal-head"><div class="modal-title">Новая задача</div><button class="modal-close" id="closeCreateModal" type="button">×</button></div>
<form id="createTaskForm" class="modal-form">
	<div id="createTaskError" class="auth-error full" hidden></div>
	<div class="modal-field full"><label>Название</label><div class="voice-input-wrap"><input id="createTaskName" name="title" placeholder="Например, собрать рюкзак" required/><button type="button" class="voice-btn" data-target="createTaskName" title="Голосовой ввод">🎤</button></div></div>
	<div class="modal-field"><label>Дата</label><input id="createTaskDate" name="date" type="date" required/></div>
	<div class="modal-field time-field-wrap">
		<label>Время (начало–конец)</label>
		<div class="time-input-row">
			<input class="time-seg" id="createStartH" type="number" min="0" max="23" placeholder="ЧЧ"/>
			<span class="time-sep">:</span>
			<input class="time-seg" id="createStartM" type="number" min="0" max="59" placeholder="ММ"/>
			<span class="time-range-sep">–</span>
			<input class="time-seg" id="createEndH" type="number" min="0" max="23" placeholder="ЧЧ"/>
			<span class="time-sep">:</span>
			<input class="time-seg" id="createEndM" type="number" min="0" max="59" placeholder="ММ"/>
		</div>
		<div class="time-ai-row">
			<button class="time-ai-btn" type="button" id="predictCreateBtn">🤖 AI — предсказать время</button>
			<span id="predictCreateHint" style="font-size:12px;color:var(--g5);font-weight:700;"></span>
		</div>
	</div>
	<div class="modal-field full"><label>Описание</label><div class="voice-input-wrap"><textarea id="createTaskDesc" name="desc" placeholder="Что нужно сделать" required></textarea><button type="button" class="voice-btn" data-target="createTaskDesc" title="Голосовой ввод">🎤</button></div></div>
	<div class="modal-actions full">
		<button class="modal-secondary" id="cancelCreateModal" type="button">Отмена</button>
		<button class="modal-primary" type="submit">Сохранить</button>
	</div>
</form>
</div>
</div>

<!-- Modal: View/Edit Task -->
<div id="viewModal" class="modal-backdrop" hidden>
<div class="modal" role="dialog" aria-modal="true">
<div class="modal-head"><div class="modal-title">Задача</div><button class="modal-close" id="closeViewModal" type="button">×</button></div>
<div class="modal-actions-top" id="viewTaskActions" style="justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;"></div>
<form id="editTaskForm" class="modal-form">
	<div id="editTaskError" class="auth-error full" hidden></div>
	<div class="modal-field full"><label>Название</label><div class="voice-input-wrap"><input id="editTaskName" name="title" required/><button type="button" class="voice-btn" data-target="editTaskName" title="Голосовой ввод">🎤</button></div></div>
	<div class="modal-field"><label>Дата</label><input id="editTaskDate" name="date" type="date" required/></div>
	<div class="modal-field time-field-wrap">
		<label>Время (начало–конец)</label>
		<div class="time-input-row">
			<input class="time-seg" id="editStartH" type="number" min="0" max="23" placeholder="ЧЧ"/>
			<span class="time-sep">:</span>
			<input class="time-seg" id="editStartM" type="number" min="0" max="59" placeholder="ММ"/>
			<span class="time-range-sep">–</span>
			<input class="time-seg" id="editEndH" type="number" min="0" max="23" placeholder="ЧЧ"/>
			<span class="time-sep">:</span>
			<input class="time-seg" id="editEndM" type="number" min="0" max="59" placeholder="ММ"/>
		</div>
		<div class="time-ai-row">
			<button class="time-ai-btn" type="button" id="predictEditBtn">🤖 AI — предсказать время</button>
			<span id="predictEditHint" style="font-size:12px;color:var(--g5);font-weight:700;"></span>
		</div>
	</div>
	<div class="modal-field full"><label>Описание</label><div class="voice-input-wrap"><textarea id="editTaskDesc" name="desc" required></textarea><button type="button" class="voice-btn" data-target="editTaskDesc" title="Голосовой ввод">🎤</button></div></div>
	<!-- Файл учителя — ссылка для скачивания -->
	<div id="teacherFileRow" class="full" style="display:none">
		<div style="font-size:13px;font-weight:700;color:var(--b2);margin-bottom:6px">📎 Файл от учителя</div>
		<div class="file-attached">
			<span>📄</span><span id="teacherFileName"></span>
			<a id="teacherFileLink" href="#" target="_blank" style="margin-left:auto;color:var(--g5);font-weight:700;font-size:13px;text-decoration:none">⬇ Скачать</a>
		</div>
	</div>
	<!-- Файл ученика -->
	<div id="fileUploadSection" class="modal-field full" style="display:none">
		<label>Прикрепить выполненную работу</label>
		<div id="fileDropZone" class="file-upload-zone">
			<input type="file" id="taskFileInput" accept="*/*"/>
			<div class="file-upload-label">📎 <strong>Выберите файл</strong> или перетащите сюда</div>
		</div>
		<div id="fileAttachedInfo" style="display:none" class="file-attached">
			<span>📄</span><span id="fileAttachedName"></span>
			<button class="file-attached-remove" id="fileRemoveBtn" type="button">×</button>
		</div>
	</div>
	<!-- Файл ученика уже загружен -->
	<div id="studentFileDownloadRow" class="full" style="display:none">
		<div style="font-size:13px;font-weight:700;color:var(--b2);margin-bottom:6px">📤 Ваша работа</div>
		<div class="file-attached">
			<span>📄</span><span id="studentFileDownloadName"></span>
			<a id="studentFileDownloadLink" href="#" target="_blank" style="margin-left:auto;color:var(--g5);font-weight:700;font-size:13px;text-decoration:none">⬇ Скачать</a>
		</div>
	</div>
	<div class="modal-actions full">
		<button class="modal-secondary" id="cancelViewModal" type="button">Закрыть</button>
		<button class="modal-primary" type="submit">Сохранить изменения</button>
	</div>
</form>
</div>
</div>

