$bog_tracker_mpit_neolo_student_stats_invitation $mol_view
	invitation_id \
	invitation_title \
	invitation_sub \
	accept_label @ \Принять
	reject_label @ \Отклонить
	accept_click? null
	reject_click? null
	sub /
		<= Inv_title $mol_view
			sub /
