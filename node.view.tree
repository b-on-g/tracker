$giper_baza_status $mol_select
	minimal_width 40
	minimal_height 40
	Filter null
	option_content* /
		<= Option_logo* $mol_avatar
			id <= master_id* \
		<= option_label*
	trigger_content /
		<= Link $mol_link
			uri <= master_link \
			sub <= link_content /
				<= Well $mol_avatar
					id <= master_link \
				<= Fail $mol_icon_sync_off
			hint <= message <= hint \Sync status

$bog_tracker_progress $mol_view
	done_count 0
	total_count 0
	label \0 / 0
	percent_width \0%
	sub /
		<= Track $mol_view
			sub /
				<= Fill $mol_view
					style *
						width <= percent_width
		<= Label $mol_view
			sub / <= label

$bog_tracker_app $mol_page
	title @ \Трекер
	store $bog_tracker_store
	pages *
		home <= Home $bog_tracker_list
			store <= store
		new <= New $bog_tracker_task_form
			store <= store
		task <= Task $bog_tracker_task_page
			store <= store
		profile <= Profile $bog_tracker_profile_page
			store <= store
		lk <= Lk $bog_lk
	nav_options *
		home @ \Задачи
		profile @ \Профиль
		lk @ \Личный кабинет
	Navbar $mol_switch
		value? <=> screen? \home
		options <= nav_options
	Progress $bog_tracker_progress
		done_count <= done_count 0
		total_count <= total_count 0
	tools /
		<= Progress
		<= Sources $mol_link_source
			uri \https://github.com/b-on-g/tracker
		<= Status $giper_baza_status
		<= Theme_toggle $bog_theme_toggle
			theme_auto <= Theme
	head /
		<= Title
		<= Navbar
		<= Tools
	plugins /
		<= Theme $bog_theme_auto
			theme_light \$mol_theme_calm_light
			theme_dark \$mol_theme_calm_dark
			themes /
				\$mol_theme_calm_light
				\$mol_theme_calm_dark
	body <= screen_body /
