$mol_speck $mol_view
	theme \$mol_theme_accent
	sub /
		<= value null

$mol_button $mol_view
	enabled true
	click?event null
	event_click?event null
	status? /
	event *
		^
		click?event <=> activate?event <=> event_activate?event null
		dblclick?event <=> clicks?event null
		keydown?event <=> key_press?event <=> event_key_press?event null
	attr *
		^
		disabled <= disabled false
		role \button
		tabindex <= tab_index 0
		title <= hint_safe <= hint \
	sub /$mol_view_content
		<= title
	Speck $mol_speck
		value <= error \

$mol_button_typed $mol_button
	minimal_height 40
	minimal_width 40

$mol_button_minor $mol_button_typed

$mol_check $mol_button_minor
	attr *
		^
		mol_check_checked <= checked? false
		aria-checked <= aria_checked \false
		role <= aria_role \checkbox
	sub /$mol_view_content
		<= Icon null
		<= label /
			<= Title $mol_view
				sub /
					<= title \

$mol_check_list $mol_view
	dictionary *
	Option* $mol_check
		checked? <=> option_checked*? false
		label <= option_label* /
			<= option_title* \
		enabled <= option_enabled* <= enabled true
		hint <= option_hint* \
		minimal_height 24
	options *
	keys /string
	sub <= items /$mol_check

$mol_switch $mol_check_list
	value? \

$mol_hotkey $mol_plugin
	event *
		^
		keydown?event <=> keydown?event null
	key *
	mod_ctrl false
	mod_alt false
	mod_shift false

$mol_string $mol_view
	dom_name \input
	enabled true
	minimal_height 40
	autocomplete false
	selection? /number
		0
		0
	auto /
		<= selection_watcher null
		<= error_report null
	field *
		^
		disabled <= disabled false
		value <= value_changed? <=> value? \
		placeholder <= hint_visible <= hint \
		spellcheck <= spellcheck true
		autocomplete <= autocomplete_native \
		selectionEnd <= selection_end 0
		selectionStart <= selection_start 0
		inputMode <= keyboard \text
		enterkeyhint <= enter \go
	attr *
		^
		maxlength <= length_max +Infinity
		type <= type? \text
	event *
		^
		input?event <=> event_change?event null
	plugins /
		<= Submit $mol_hotkey
			mod_ctrl <= submit_with_ctrl false
			key * enter?event <=> submit?event null

$mol_list $mol_view
	render_visible_only true
	render_over 0.1
	sub <= rows /$mol_view
		<= Gap_before $mol_view style * paddingTop <= gap_before 0
		<= Empty $mol_view
		<= Gap_after $mol_view style * paddingTop <= gap_after 0
	item_height_min* 1
	item_width_min* 1
	view_window_shift? 0
	view_window /
		0
		0

$mol_labeler $mol_list
	rows /
		<= Label $mol_view
			minimal_height 32
			sub <= label /$mol_view_content
				<= title
		<= Content $mol_view
			minimal_height 24
			sub <= content /

$mol_button_major $mol_button_minor
	theme \$mol_theme_base

$bog_tracker_mpit_neolo_auth $mol_view
	store $bog_tracker_mpit_neolo_store
	mode? \login
	mode_options *
		login @ \Войти
		register @ \Регистрация
	role? \
	error? \
	busy? false
	has_error false
	is_login_mode true
	is_register_mode false
	needs_school_field false
	login_username? \
	login_password? \
	reg_username? \
	reg_password? \
	reg_password2? \
	reg_name? \
	reg_surname? \
	reg_school? \
	attr *
		^
		bog_tracker_mpit_neolo_auth_busy <= busy
	sub /
		<= Card $mol_view
			sub /
				<= Brand $mol_view
					sub /
						\School
						<= Brand_accent $mol_view
							sub /
								\Plan
				<= Sub $mol_view
					sub /
						\Планировщик для школьников
				<= Tabs $mol_switch
					value? <=> mode? \login
					options <= mode_options
				<= Error_view $mol_view
					attr *
						^
						bog_tracker_mpit_neolo_auth_error_visible <= has_error false
					sub /
						<= error
				<= Login_form $mol_view
					attr *
						^
						bog_tracker_mpit_neolo_auth_form_visible <= is_login_mode true
					sub /
						<= Login_username_field $mol_labeler
							title @ \Логин
							content /
								<= Login_username_input $mol_string
									hint @ \Ваш логин
									value? <=> login_username? \
						<= Login_password_field $mol_labeler
							title @ \Пароль
							content /
								<= Login_password_input $mol_string
									hint @ \Ваш пароль
									type \password
									value? <=> login_password? \
						<= Login_submit $mol_button_major
							click? <=> login_click? null
							enabled <= login_enabled true
							sub /
								<= login_label \Войти
				<= Register_form $mol_view
					attr *
						^
						bog_tracker_mpit_neolo_auth_form_visible <= is_register_mode false
					sub /
						<= Reg_username_field $mol_labeler
							title @ \Логин
							content /
								<= Reg_username_input $mol_string
									hint @ \Придумайте логин
									value? <=> reg_username? \
						<= Reg_password_field $mol_labeler
							title @ \Пароль
							content /
								<= Reg_password_input $mol_string
									hint @ \Придумайте пароль
									type \password
									value? <=> reg_password? \
						<= Reg_password2_field $mol_labeler
							title @ \Повторите пароль
							content /
								<= Reg_password2_input $mol_string
									hint @ \Повторите пароль
									type \password
									value? <=> reg_password2? \
						<= Reg_two_col $mol_view
							sub /
								<= Reg_name_field $mol_labeler
									title @ \Имя
									content /
										<= Reg_name_input $mol_string
											hint @ \Ваше имя
											value? <=> reg_name? \
								<= Reg_surname_field $mol_labeler
									title @ \Фамилия
									content /
										<= Reg_surname_input $mol_string
											hint @ \Ваша фамилия
											value? <=> reg_surname? \
						<= Reg_role_label $mol_view
							sub /
								\Кто вы?
						<= Reg_role_grid $mol_view
							sub /
								<= Role_student $bog_tracker_mpit_neolo_auth_role_button
									role_key \student
									role_icon \🎒
									role_label @ \Ученик
									selected <= role_student_selected false
									click? <=> role_student_click? null
								<= Role_teacher $bog_tracker_mpit_neolo_auth_role_button
									role_key \teacher
									role_icon \📚
									role_label @ \Учитель
									selected <= role_teacher_selected false
									click? <=> role_teacher_click? null
								<= Role_parent $bog_tracker_mpit_neolo_auth_role_button
									role_key \parent
									role_icon \👨‍👩‍👧
									role_label @ \Родитель
									selected <= role_parent_selected false
									click? <=> role_parent_click? null
						<= Reg_school_field $mol_labeler
							attr *
								^
								bog_tracker_mpit_neolo_auth_school_visible <= needs_school_field false
							title @ \Школа
							content /
								<= Reg_school_input $mol_string
									hint @ \Например, Школа №42
									value? <=> reg_school? \
						<= Reg_submit $mol_button_major
							click? <=> register_click? null
							enabled <= register_enabled true
							sub /
								<= register_label \Зарегистрироваться

$bog_tracker_mpit_neolo_auth_role_button $mol_button_minor
	role_key \
	role_icon \
	role_label \
	selected false
	attr *
		^
		bog_tracker_mpit_neolo_auth_role_button_selected <= selected
	sub /
		<= Role_icon $mol_view
			sub / <= role_icon
		<= Role_label $mol_view
			sub / <= role_label

$bog_tracker_mpit_neolo_student_tasks $mol_view
	store $bog_tracker_mpit_neolo_store
	api $bog_tracker_mpit_neolo_api
	title_label @ \Задания
	nearest_label @ \Ближайшие задания
	add_label @ \Добавить задачу
	add_trigger_label @ \Открыть календарь и создать задачу
	task_ids /string
	add_task_click? null
	open_task*? null
	task_title* \
	task_desc* \
	task_source_label* \
	task_source_cls* \src-self
	task_status_label* \
	task_status_cls* \status-pending
	task_deadline* \
	task_rows /
	Card* $bog_tracker_mpit_neolo_student_tasks_card
		task_id* <= task_id_value* \
		task_title <= task_title* \
		task_desc <= task_desc* \
		source_label <= task_source_label* \
		source_cls <= task_source_cls* \src-self
		status_label <= task_status_label* \
		status_cls <= task_status_cls* \status-pending
		deadline <= task_deadline* \
		click? <=> open_task*? null
	sub /
		<= Title $mol_view
			sub /
				<= title_label
		<= Section_title $mol_view
			sub /
				<= nearest_label
		<= Tasks_group $mol_list
			rows <= task_rows
		<= Add_box $mol_view
			sub /
				<= Add_title $mol_view
					sub /
						<= add_label
				<= Add_trigger $mol_button_minor
					click? <=> add_task_click? null
					sub /
						<= Add_icon $mol_view
							sub /
								\+
						<= Add_text $mol_view
							sub /
								<= add_trigger_label

$bog_tracker_mpit_neolo_student_tasks_card $mol_button_minor
	task_id \
	task_title \
	task_desc \
	source_label \
	source_cls \src-self
	status_label \
	status_cls \status-pending
	deadline \
	click? null
	attr *
		^
		bog_tracker_mpit_neolo_student_tasks_card_source <= source_cls \src-self
		bog_tracker_mpit_neolo_student_tasks_card_status <= status_cls \status-pending
	sub /
		<= Bullet $mol_view
		<= Inner $mol_view
			sub /
				<= Name $mol_view
					sub /
						<= task_title
				<= Desc $mol_view
					sub /
						<= task_desc
				<= Meta_row $mol_view
					sub /
						<= Source_badge $mol_view
							attr *
								^
							sub /
								<= source_label
						<= Status_badge $mol_view
							attr *
								^
							sub /
								<= status_label
		<= Deadline $mol_view
			sub /
				<= deadline

$bog_tracker_mpit_neolo_student_calendar $mol_view
	store $bog_tracker_mpit_neolo_store
	api $bog_tracker_mpit_neolo_api
	title_label @ \Календарь
	month_label \
	view_month? 0
	view_year? 0
	selected_date? \
	add_label \+ Добавить задачу
	today_label @ \Задачи на день
	upcoming_label @ \Ближайшие события
	empty_note @ \На выбранный день задач нет.
	prev_month? null
	next_month? null
	create_click? null
	select_day*? null
	open_task*? null
	weekday_ids /
		\Пн
		\Вт
		\Ср
		\Чт
		\Пт
		\Сб
		\Вс
	cell_ids /string
	cell_day* \
	cell_count* \
	cell_has_count* false
	cell_is_selected* false
	cell_is_today* false
	cell_is_empty* false
	day_is_empty false
	selected_label \
	day_task_ids /string
	upcoming_ids /string
	day_task_time* \
	day_task_title* \
	day_task_meta* \
	upcoming_date* \
	upcoming_time* \
	upcoming_title* \
	grid_cells /
	day_tasks /
	upcoming /
	Cell* $bog_tracker_mpit_neolo_student_calendar_cell
		date_id* <= cell_date_id* \
		day_number <= cell_day* \
		count <= cell_count* \
		has_count <= cell_has_count* false
		is_selected <= cell_is_selected* false
		is_today <= cell_is_today* false
		is_empty <= cell_is_empty* false
		click? <=> select_day*? null
	Weekday* $mol_view
		sub /
			<= weekday_label* \
	Day_task* $bog_tracker_mpit_neolo_student_calendar_day_task
		task_id* <= day_task_id* \
		time <= day_task_time* \
		task_title <= day_task_title* \
		meta <= day_task_meta* \
		click? <=> open_task*? null
	Upcoming_row* $bog_tracker_mpit_neolo_student_calendar_upcoming_row
		task_id* <= upcoming_id* \
		upcoming_date <= upcoming_date* \
		upcoming_time <= upcoming_time* \
		upcoming_title <= upcoming_title* \
		click? <=> open_task*? null
	sub /
		<= Title $mol_view
			sub /
				<= title_label
		<= Calendar_layout $mol_view
			sub /
				<= Toolbar $mol_view
					sub /
						<= Nav $mol_view
							sub /
								<= Prev_btn $mol_button_minor
									click? <=> prev_month? null
									sub /
										\‹
								<= Month_label $mol_view
									sub /
										<= month_label
								<= Next_btn $mol_button_minor
									click? <=> next_month? null
									sub /
										\›
						<= Create_btn $mol_button_minor
							click? <=> create_click? null
							sub /
								<= add_label
				<= Grid $mol_view
					sub <= grid_cells
				<= Bottom $mol_view
					sub /
						<= Day_box $mol_view
							sub /
								<= Day_box_title $mol_view
									sub /
										<= today_label
								<= Selected_label $mol_view
									sub /
										<= selected_label
								<= Day_list $mol_list
									rows <= day_tasks
								<= Empty_note $mol_view
									attr *
										^
										bog_tracker_mpit_neolo_student_calendar_empty <= day_is_empty false
									sub /
										<= empty_note
						<= Upcoming_box $mol_view
							sub /
								<= Upcoming_title $mol_view
									sub /
										<= upcoming_label
								<= Upcoming_list $mol_list
									rows <= upcoming

$bog_tracker_mpit_neolo_student_calendar_cell $mol_button_minor
	date_id \
	day_number \
