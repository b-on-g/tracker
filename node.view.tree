				<= Subject_field $mol_labeler
					title \Предмет
					content /
						<= Subject_input $mol_string
							hint \Например, Математика
							value? <=> subject? \
				<= Error_view $mol_view
					sub /
						<= error
				<= Buttons $mol_view
					sub /
						<= Cancel_btn $mol_button_minor
							click? <=> close? null
							sub /
								\Отмена
						<= Submit_btn $mol_button_major
							click? <=> submit? null
							sub /
								\Создать

